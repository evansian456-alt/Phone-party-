# =============================================================================
# .env.test.example — Required environment variables for the test suite
#
# Copy this file to .env.test and fill in the values before running tests.
# DO NOT commit .env.test to source control.
#
# ⚠️  SAFETY REQUIREMENTS (READ BEFORE EDITING):
#   - STRIPE_SECRET_KEY must start with "sk_test_" — NEVER "sk_live_".
#   - STRIPE_WEBHOOK_SECRET must start with "whsec_test_" — NEVER a live value.
#   - If either key looks live, tests HARD-STOP with an error (assertStripeTestMode).
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────

NODE_ENV=test

# ── Admin seeding ─────────────────────────────────────────────────────────────
# Must match the app's ADMIN_EMAILS allowlist. The global setup uses this email
# when seeding the admin user into the ephemeral Postgres container.
ADMIN_EMAIL=ianevans2023@outlook.com

# ── Seed user password ────────────────────────────────────────────────────────
# Password used for ALL seeded users (admin, host, guest).
# Must satisfy the app's password policy (8+ chars, mixed case, digit).
TEST_USER_PASSWORD=ChangeMe123!

# ── Database ──────────────────────────────────────────────────────────────────
# Set dynamically by Testcontainers in globalSetup.js.
# Leave blank here — the global setup exports DATABASE_URL before any test runs.
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Set dynamically by Testcontainers in globalSetup.js.
# Leave blank here — the global setup exports REDIS_URL before any test runs.
REDIS_URL=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=test-secret-for-testing-only-do-not-use-in-production-32chars

# ── Stripe (TEST KEYS ONLY) ───────────────────────────────────────────────────
# Use Stripe test-mode keys. Never use live keys here.
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxx

# Optional: Stripe test-mode Price IDs (from dashboard → Products → test mode)
STRIPE_PRICE_PARTY_PASS=price_party_pass_test
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_test

# ── App server ────────────────────────────────────────────────────────────────
# Set dynamically by the e2e runner. Leave blank or set to a fixed port for
# manual test runs.
PUBLIC_BASE_URL=http://127.0.0.1:
PORT=0
