# Phone Party - Environment Configuration
#
# See docs/ENVIRONMENT.md for complete documentation of all variables
#
# Legend:
# 🔴 REQUIRED (Production) - Must be set or production will fail
# 🟡 STRONGLY RECOMMENDED - Optional but critical for security
# 🟢 OPTIONAL - Has safe defaults
# 🔵 DEV ONLY - Only used in development/testing

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# 🟡 STRONGLY RECOMMENDED - Define runtime environment
# Values: production, development, test
# Controls security settings, error verbosity, and TLS validation
NODE_ENV=development

# 🟢 OPTIONAL - HTTP server port (cloud platforms set this automatically)
PORT=8080

# 🔴 PRODUCTION REQUIRED - Public Base URL for HTTPS proxies (Railway, Heroku, etc.)
# Used to generate correct trackUrl for uploaded audio files
# For Railway: Set to your Railway domain
# For local dev: Leave unset (will auto-detect from request)
# Example: PUBLIC_BASE_URL=https://your-app.up.railway.app
# PUBLIC_BASE_URL=

# ============================================================================
# STORAGE CONFIGURATION (Audio Track Storage)
# 🔴 REQUIRED IN PRODUCTION for multi-instance deployments
# ============================================================================

# S3-Compatible Storage (Railway Buckets, Cloudflare R2, AWS S3)
# Required in production, optional in dev (uses local disk if not configured)
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT=https://s3.railway.app  # For Railway Buckets
# S3_REGION=auto  # Use 'auto' for R2, or AWS region like 'us-east-1'
# S3_FORCE_PATH_STYLE=true  # Set to true for R2 and some S3-compatible services
# S3_PREFIX=tracks/  # Optional folder prefix

# 🟢 OPTIONAL - CDN and Direct R2 Playback URLs (PHASE 1)
# If set, clients stream directly from CDN/R2 instead of proxying through /api/track
# CDN_BASE_URL - Cloudflare CDN domain (highest priority for playback)
# S3_PUBLIC_BASE_URL - Direct R2 public URL (used if CDN_BASE_URL not set)
# CDN_BASE_URL=https://cdn.example.com
# S3_PUBLIC_BASE_URL=https://pub-abc123.r2.dev

# 🔵 DEV ONLY - Local Disk Storage (fallback when S3 not configured)
# UPLOAD_DIR=./uploads
# ALLOW_LOCAL_DISK_IN_PROD=false  # NOT recommended for multi-instance

# 🟢 OPTIONAL - Maximum upload file size in bytes (default: 52428800 = 50MB)
# Applies to both /api/upload-track (multer) and /api/tracks/presign-put (server-side check).
# Presigned uploads: sizeBytes in the request body is validated against this limit before
# the presigned URL is issued. multer limits do NOT apply to presigned PUT uploads.
# TRACK_MAX_BYTES=52428800

# ============================================================================
# REDIS CONFIGURATION (Cache & Pub/Sub)
# 🔴 REQUIRED IN PRODUCTION for multi-device sync
# ============================================================================
# 🔴 PRODUCTION REQUIRED - Full Redis connection URL (preferred method)
# Railway/Heroku set this automatically when you add Redis
# Format: redis://[user]:[password]@[host]:[port] or rediss:// for TLS
# Example: REDIS_URL=rediss://default:mypassword@redis.example.com:6379
# REDIS_URL=

# 🔵 DEV ONLY - Individual Redis settings (only when REDIS_URL not set)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment if your local Redis requires auth

# 🟢 OPTIONAL - TLS certificate validation for Redis
# Default: false (compatible with Railway/managed services)
# Set to 'true' for strict validation in production with proper certificates
# REDIS_TLS_REJECT_UNAUTHORIZED=false

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# 🔴 REQUIRED IN PRODUCTION for user accounts, subscriptions, purchases
# ============================================================================

# 🔴 PRODUCTION REQUIRED - PostgreSQL connection string (preferred method)
# Railway/Heroku set this automatically when you add PostgreSQL
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Example: DATABASE_URL=postgresql://dbuser:dbpass@db.example.com:5432/phoneparty
DATABASE_URL=postgresql://localhost:5432/phoneparty

# 🔵 DEV ONLY - Individual database settings (only when DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phoneparty
DB_USER=postgres
# DB_PASSWORD=  # Uncomment if your local PostgreSQL requires auth

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# 🔴 PRODUCTION REQUIRED - JWT signing secret
# ⚠️  REQUIRED IN PRODUCTION: The server will CRASH at startup if not set when NODE_ENV=production
# ⚠️  In development/test, an insecure fallback is used (warns to console)
# Generate with: openssl rand -base64 48
# Minimum 32 characters required
# Example: JWT_SECRET=your-super-secret-random-string-min-32-chars
# JWT_SECRET=

# ============================================================================
# PAYMENT INTEGRATION (Optional)
# 🟢 All payment variables are optional - app works without them
# ============================================================================

# Stripe Payment Processing
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...  # For production
# STRIPE_SECRET_KEY=sk_test_...  # For testing
# STRIPE_WEBHOOK_SECRET=whsec_...  # For webhook validation

# Apple In-App Purchases (iOS)
# APPLE_IAP_SHARED_SECRET=

# Google Play In-App Purchases (Android)
# GOOGLE_PLAY_SERVICE_ACCOUNT=

# ============================================================================
# MONITORING & OBSERVABILITY (Optional)
# 🟢 Optional but recommended for production
# ============================================================================

# Sentry Error Tracking
# Get your DSN from: https://sentry.io
# Only active when NODE_ENV=production
# SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# Google Analytics 4
# Get your Measurement ID from: https://analytics.google.com
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# ADMIN & DEBUG (Development Only)
# 🔵 DEV ONLY - Never use in production
# ============================================================================

# Admin dashboard access secret (optional, dev allows without secret)
# ADMIN_SECRET=

# Enable verbose debug logging (performance impact)
# DEBUG=false

# Enable test mode behaviors (auto-detected in test environment)
# TEST_MODE=false

# ============================================================================
# FEATURE FLAGS (Advanced)
# 🟢 Optional - defaults are recommended for most deployments
# ============================================================================

# Enable Redis pub/sub for multi-instance communication
# ENABLE_PUBSUB=true

# Enable reaction history storage
# ENABLE_REACTION_HISTORY=true

# ⚠️  DANGER: Allow in-memory fallback when Redis unavailable in production
# Should ALWAYS be false - in-memory breaks multi-instance deployments
# ALLOW_FALLBACK_IN_PRODUCTION=false

# ============================================================================
# PRODUCTION MINIMUM CONFIGURATION
# ============================================================================
# 
# Absolute minimum for production:
#   NODE_ENV=production
#   REDIS_URL=rediss://...
#   DATABASE_URL=postgresql://...
#   JWT_SECRET=<secure-random-string>
#
# See docs/ENVIRONMENT.md for complete production setup guide

